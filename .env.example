ENV=development
PORT=8080
DATABASE_URL=postgres://guardpoint:guardpoint@localhost:5432/guardpoint?sslmode=disable
LOG_LEVEL=debug
LOG_FORMAT=text
# Em producao (ENV=production) o servidor recusa o placeholder abaixo e exige
# um segredo com pelo menos 32 caracteres.
JWT_SECRET=change-me-in-production
# Em producao o servidor recusa "*"; liste as origens separadas por virgula.
CORS_ORIGIN=*
# Opcional: se definido, /metrics exige "Authorization: Bearer <token>".
METRICS_TOKEN=
